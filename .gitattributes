# Normalize line endings. Shell scripts MUST stay LF or the container's
# `#!/usr/bin/env bash` fails with "bad interpreter" on a CRLF checkout.
* text=auto eol=lf
*.sh text eol=lf
*.py text eol=lf
*.js text eol=lf
*.css text eol=lf
*.yml text eol=lf
Dockerfile text eol=lf
*.png binary
*.jpg binary
*.pth binary
